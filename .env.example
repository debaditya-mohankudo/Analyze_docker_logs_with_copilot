# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here
MODEL_NAME=gpt-4o-mini

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
LOGS_TOPIC_NAME=docker-logs
CONSUMER_GROUP_ID=log-analyzer-group

# Docker Configuration
DOCKER_HOST=unix:///var/run/docker.sock
# Optional: Filter containers by label (leave empty to monitor all)
CONTAINER_LABEL_FILTER=

# Analysis Configuration
CONTEXT_WINDOW_SECONDS=60
DEBOUNCE_SECONDS=10
LLM_ERROR_THRESHOLD=10  # Minimum errors to trigger LLM analysis (cost optimization)

# Analytics Configuration
ANALYTICS_ENABLED=true
ANALYTICS_INTERVAL=10.0  # Seconds between analytics snapshots

# Logging Configuration
LOG_LEVEL=INFO
